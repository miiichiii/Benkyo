rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function parentViewer() {
      return signedIn()
        && request.auth.token.email == 'hamamicchi@gmail.com';
    }

    function anonymousChild() {
      return signedIn()
        && request.auth.token.email == null;
    }

    function ayameRecord(familyId, childId) {
      return familyId == 'hamada-kuku' && childId == 'ayame';
    }

    match /kukuFamilies/{familyId}/children/{childId} {
      allow list: if parentViewer();
      allow get: if parentViewer() || (anonymousChild() && ayameRecord(familyId, childId));
      allow create, update: if anonymousChild() && ayameRecord(familyId, childId);
      allow delete: if false;

      match /attempts/{attemptId} {
        allow list, get: if parentViewer();
        allow create, update: if anonymousChild() && ayameRecord(familyId, childId);
        allow delete: if false;
      }
    }
  }
}

// Home-use rules for this version:
// - Parent viewer reads only after Google login as hamamicchi@gmail.com.
// - Child app writes automatically with Firebase Anonymous Auth.
// - Writes are limited to /kukuFamilies/hamada-kuku/children/ayame.
